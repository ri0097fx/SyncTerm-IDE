[remote]
# 【要編集】接続するリモートサーバーのユーザー名とホスト名
server = user@relay-host

# アプリルートは ~/SyncTerm-IDE に統一。sessions / _registry はその下に自動作成される（base_path は廃止）。

# 【任意】デプロイ先ディレクトリ（scripts/deploy_backend.sh の第2引数省略時に使用）
# 未指定時は ~/SyncTerm-IDE。Relay 上でアプリを置くパス（例: ~/mnt）
# deploy_dir = ~/mnt

[local_paths]
# 【要編集】GUIクライアントが使用するローカルミラーのパス
gui_mirror_dir = ~/gui_local_mirror

# 【要編集】Watcherマネージャーが使用するローカルミラーのパス
watcher_mirror_dir = ~/watcher_local_mirror

[structure]
# セッションディレクトリを格納するディレクトリ名（通常は変更不要）
sessions_dir_name = sessions

# Watcherの稼働状況を登録するディレクトリ名（通常は変更不要）
registry_dir_name = _registry

[rt]
# リバーストンネル版 Watcher 用（watcher_manager_rt.sh）
rt_port = 9001
backend_port = 8000
relay_local_port = 8001

[ai]
# エディタの AI アシスト用（任意）。未設定時は Ollama を優先（API キー不要）
# 使用するプロバイダー: ollama または openai
# ai_provider = ollama
# Ollama の URL（Relay 上で ollama serve を起動している場合）
# ollama_base_url = http://127.0.0.1:11434
# Ollama のモデル名（軽量: qwen2.5-coder:1.5b / 標準: qwen2.5-coder:7b）
# ollama_model = qwen2.5-coder:7b
